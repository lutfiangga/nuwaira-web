# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Optional: dedicated URL for drizzle-kit migrate/push/introspect.
# For Supabase, use direct connection or session pooler on port 5432 (NOT transaction pooler 6543).
DATABASE_URL_MIGRATION="postgres://user:password@host:5432/db-name"
